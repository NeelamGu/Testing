{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.4",
      "excludeFiles": "{public/admin/**,public/front/images/**,public/front/videos/**,public/front/fonts/**,public/storage/**,storage/logs/**,tests/**,old/**,database.sql,Default.html,cat_list.txt,pop_cat.txt,prod_list.txt}"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.(?:css|js|mjs|map|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|txt|xml))",
      "dest": "/public/$1"
    },
    {
      "src": "/$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(login|register|home)$",
      "dest": "/api/index.php"
    },
    {
      "src": "/user(?:/.*)?$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(get-user-enquiries|update-enquiry-status|delete-enquiry|update-pin-status|get-city|get-city-state|get-countrycode|write-a-review)$",
      "dest": "/api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/preview-only.html"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "array",
    "LOG_CHANNEL": "stderr",
    "VIEW_COMPILED_PATH": "/tmp/views",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php"
  }
}