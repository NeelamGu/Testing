{
  "version": 2,
  "routes": [
    {
      "src": "/(.*\\.(?:css|js|mjs|map|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot|txt|xml))",
      "dest": "/public/$1"
    },
    {
      "src": "/$",
      "dest": "/public/preview-only.html"
    },
    {
      "src": "/user/account$",
      "dest": "/public/user-panel-preview.html"
    },
    {
      "src": "/preview/user-panel$",
      "dest": "/public/user-panel-preview.html"
    },
    {
      "src": "/preview/translation$",
      "dest": "/public/translation-preview.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/preview-only.html"
    }
  ]
}